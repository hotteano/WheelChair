{
  "name": "wheelchair",
  "version": "1.0.1",
  "description": "A modern, extensible rich text editor based on Tiptap",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter demo dev",
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @wheelchair/core build",
    "test": "pnpm -r test",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache"
  },
  "keywords": [
    "rich-text-editor",
    "tiptap",
    "react",
    "typescript",
    "wysiwyg"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.10.0"
}
