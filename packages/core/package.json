{
  "name": "@wheelchair/core",
  "version": "1.0.1",
  "description": "Core package for WheelChair rich text editor",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
